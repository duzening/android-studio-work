class MapBackgroundPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = const Color(0xFFE8F5E9)
      ..style = PaintingStyle.fill;
    canvas.drawRect(Rect.fromLTWH(0, 0, size.width, size.height), paint);

    final borderPaint = Paint()
      ..color = const Color(0xFFB2DFDB)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 2.5;

    final path = Path();
    path.moveTo(size.width * 0.15, size.height * 0.3);
    path.quadraticBezierTo(size.width * 0.4, size.height * 0.1,
        size.width * 0.75, size.height * 0.2);
    path.quadraticBezierTo(size.width * 0.9, size.height * 0.35,
        size.width * 0.85, size.height * 0.6);
    path.quadraticBezierTo(size.width * 0.7, size.height * 0.85,
        size.width * 0.4, size.height * 0.8);
    path.quadraticBezierTo(size.width * 0.2, size.height * 0.75,
        size.width * 0.1, size.height * 0.55);
    path.close();

    final fillPaint = Paint()
      ..color = const Color(0xFFE0F2F1)
      ..style = PaintingStyle.fill;
    canvas.drawPath(path, fillPaint);
    canvas.drawPath(path, borderPaint);

    final seaPaint = Paint()
      ..color = const Color(0xFFB3E5FC).withOpacity(0.5)
      ..style = PaintingStyle.fill;
    final seaPath = Path();
    seaPath.moveTo(size.width * 0.75, size.height * 0.2);
    seaPath.quadraticBezierTo(
        size.width * 0.95, size.height * 0.1, size.width, size.height * 0.3);
    seaPath.lineTo(size.width, size.height);
    seaPath.lineTo(size.width * 0.5, size.height);
    seaPath.quadraticBezierTo(size.width * 0.85, size.height * 0.6,
        size.width * 0.85, size.height * 0.6);
    seaPath.quadraticBezierTo(size.width * 0.9, size.height * 0.35,
        size.width * 0.75, size.height * 0.2);
    canvas.drawPath(seaPath, seaPaint);

    final gridPaint = Paint()
      ..color = Colors.grey.withOpacity(0.08)
      ..strokeWidth = 0.8;

    for (double x = 0; x < size.width; x += 40) {
      canvas.drawLine(Offset(x, 0), Offset(x, size.height), gridPaint);
    }
    for (double y = 0; y < size.height; y += 40) {
      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
}

