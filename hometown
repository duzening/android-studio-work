  AIResult _calculateResult() {
    int dongyingScore = 0;
    int yantaiScore = 0;
    int liaochengScore = 0;

    if (answers[0] == 0) dongyingScore += 3;
    if (answers[0] == 1) yantaiScore += 3;
    if (answers[0] == 2) liaochengScore += 3;

    if (answers[1] == 0) {
      dongyingScore += 2;
      yantaiScore += 1;
    }
    if (answers[1] == 1) yantaiScore += 2;
    if (answers[1] == 2) liaochengScore += 2;

    if (answers[2] == 0) dongyingScore += 3;
    if (answers[2] == 1) yantaiScore += 3;
    if (answers[2] == 2) liaochengScore += 3;

    final scores = {
      cities[0]: dongyingScore,
      cities[1]: yantaiScore,
      cities[2]: liaochengScore,
    };

    final bestEntry =
    scores.entries.reduce((a, b) => a.value >= b.value ? a : b);
    final bestCity = bestEntry.key;
    final bestScore = bestEntry.value;

    String reason;
    if (bestCity.name == '东营') {
      reason = '根据你的选择，你更偏爱生态自然景观，享受湿地的宁静与候鸟飞舞的壮观。东营的黄河口湿地和天鹅湖将为你带来最纯粹的自然体验。';
    } else if (bestCity.name == '烟台') {
      reason = '你明显更向往海边风光和轻松浪漫的旅行节奏。烟台迷人的海岸线、神话传说中的蓬莱阁，以及丰富的海鲜美食，将给你留下难忘的旅行记忆。';
    } else {
      reason = '你对历史文化和古城风貌有着浓厚兴趣。聊城的光岳楼、东昌湖和大运河文化将带你穿越时空，感受千年历史的厚重底蕴。';
    }

    final match = 70 + bestScore * 3;

    return AIResult(
      city: bestCity,
      match: match > 98 ? 98 : match,
      reason: reason,
    );
  }
}

class AIResult {
  final CityData city;
  final int match;
  final String reason;

  AIResult({required this.city, required this.match, required this.reason});
}
