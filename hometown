                        ],
                      ),
                      child: const Center(
                        child: Text('🗺️', style: TextStyle(fontSize: 60)),
                      ),
                    ),
                    const SizedBox(height: 32),
                    const Text(
                      'Explore Shandong',
                      style: TextStyle(
