// ==================== 数据模型 ====================

class CityData {
  final String name;
  final String subtitle;
  final String titleTag;
  final String description;
  final Color color;
  final Color secondaryColor;
  final IconData icon;
  final List<String> tags;
  final List<Attraction> attractions;
  final List<Food> foods;
  final List<RoutePlan> routes;
  final String imageUrl;
  final String heroEmoji;

  const CityData({
    required this.name,
    required this.subtitle,
    required this.titleTag,
    required this.description,
    required this.color,
    required this.secondaryColor,
    required this.icon,
    required this.tags,
    required this.attractions,
    required this.foods,
    required this.routes,
    required this.imageUrl,
    required this.heroEmoji,
  });
}

class Attraction {
  final String name;
  final String description;
  final int rating;
  final List<String> suitableFor;
  final String imageUrl;
  final String emoji;

  const Attraction({
    required this.name,
    required this.description,
    required this.rating,
    required this.suitableFor,
    required this.imageUrl,
    required this.emoji,
  });
}

class Food {
  final String name;
  final String area;
  final int rating;
  final int price;
  final String description;
  final String emoji;
  final String imageUrl; // ✨ 新增字段

  const Food({
    required this.name,
    required this.area,
    required this.rating,
    required this.price,
    required this.description,
    required this.emoji,
    required this.imageUrl,
  });
}

class RoutePlan {
  final String title;
  final List<RouteItem> items;

  const RoutePlan({required this.title, required this.items});
}

class RouteItem {
  final String time;
  final String place;
  final String icon;

  const RouteItem({required this.time, required this.place, required this.icon});
}

